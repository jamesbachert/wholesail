generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// REGIONS & CONFIGURATION
// ============================================================

model Region {
  id          String   @id @default(cuid())
  name        String   // "Greater Lehigh Valley"
  slug        String   @unique // "lehigh-valley"
  state       String   // "PA"
  counties    String[] // ["Lehigh", "Northampton", "Berks"]
  zipCodes    String[] // All zip codes in the region
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  leads       Lead[]
  dataSources DataSource[]
  zipAnalyses ZipCodeAnalysis[]
}

model ZipCodeAnalysis {
  id              String   @id @default(cuid())
  zipCode         String
  regionId        String
  region          Region   @relation(fields: [regionId], references: [id])
  totalProperties Int      @default(0)
  avgPropertyValue Float?
  saturationScore  Float   @default(0)
  competitorCount  Int     @default(0)
  leadDensity      Float   @default(0)
  lastAnalyzed     DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([zipCode, regionId])
}

// ============================================================
// PROPERTIES & OWNERS
// ============================================================

model Property {
  id              String   @id @default(cuid())
  address         String
  city            String
  state           String
  zipCode         String
  county          String?

  propertyType    String?
  bedrooms        Int?
  bathrooms       Float?
  sqft            Int?
  lotSize         Float?
  yearBuilt       Int?

  assessedValue   Float?
  estimatedValue  Float?
  estimatedEquity Float?

  ownerName       String?
  ownerMailingAddress String?
  ownerCity       String?
  ownerState      String?
  ownerZip        String?
  ownerPhone      String?
  ownerPhone2     String?
  ownerEmail      String?
  isAbsenteeOwner Boolean  @default(false)
  ownershipLength Int?

  isVacant        Boolean  @default(false)
  hasCodeViolations Boolean @default(false)

  latitude        Float?
  longitude       Float?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lead            Lead?
  sourceRecords   SourceRecord[]

  @@index([zipCode])
  @@index([city, state])
}

// ============================================================
// LEADS
// ============================================================

enum LeadStatus {
  NEW
  CONTACTED
  WARM
  HOT
  UNDER_CONTRACT
  HANDED_OFF
  CLOSED
  DEAD
  DO_NOT_CONTACT
}

model Lead {
  id              String     @id @default(cuid())
  propertyId      String     @unique
  property        Property   @relation(fields: [propertyId], references: [id])
  regionId        String
  region          Region     @relation(fields: [regionId], references: [id])

  // Scoring
  automatedScore  Float      @default(0)
  manualScore     Float      @default(0)
  totalScore      Float      @default(0)

  // Status tracking
  status          LeadStatus @default(NEW)
  priority        String     @default("normal")
  isTimeSensitive Boolean    @default(false)
  timeSensitiveReason String?
  timeSensitiveDeadline DateTime?

  // Assignment
  assignedTo      String?

  // Key Dates
  lastActivityAt  DateTime   @default(now())
  lastSignalAt    DateTime?
  archivedAt      DateTime?
  firstDiscovered DateTime   @default(now())
  lastContacted   DateTime?
  nextFollowUp    DateTime?

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  signals         LeadSignal[]
  contacts        ContactLog[]
  notes           LeadNote[]
  handoffs        Handoff[]

  @@index([totalScore(sort: Desc)])
  @@index([status])
  @@index([regionId])
  @@index([isTimeSensitive])
  @@index([lastActivityAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

// ============================================================
// SCORING SIGNALS
// ============================================================

model ScoringWeight {
  id          String   @id @default(cuid())
  signalType  String   @unique
  label       String
  category    String   // "distress", "ownership", "timing", "financial", "condition"
  weight      Float
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LeadSignal {
  id          String    @id @default(cuid())
  leadId      String
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  signalType  String
  label       String
  category    String
  value       String?
  points      Float
  source      String?
  discoveredAt DateTime @default(now())

  isAutomated Boolean   @default(false)
  isLocked    Boolean   @default(false)
  isActive    Boolean   @default(true)
  eventDate   DateTime?
  metadata    Json?

  createdAt   DateTime  @default(now())

  @@index([leadId])
  @@index([signalType])
}

// ============================================================
// DATA SOURCES
// ============================================================

enum SourceStatus {
  ACTIVE
  PAUSED
  ERROR
  PENDING
}

model DataSource {
  id            String       @id @default(cuid())
  name          String
  slug          String       @unique
  type          String
  regionId      String
  region        Region       @relation(fields: [regionId], references: [id])
  url           String?
  status        SourceStatus @default(PENDING)
  lastRun       DateTime?
  lastSuccess   DateTime?
  recordsFound  Int          @default(0)
  errorMessage  String?
  config        Json?
  schedule      String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  records       SourceRecord[]
}

model SourceRecord {
  id           String     @id @default(cuid())
  dataSourceId String
  dataSource   DataSource @relation(fields: [dataSourceId], references: [id])
  propertyId   String?
  property     Property?  @relation(fields: [propertyId], references: [id])
  rawData      Json
  processedAt  DateTime?
  createdAt    DateTime   @default(now())

  @@index([dataSourceId])
}

// ============================================================
// CONTACT HISTORY
// ============================================================

enum ContactType {
  CALL_OUTBOUND
  CALL_INBOUND
  SMS_OUTBOUND
  SMS_INBOUND
  EMAIL_OUTBOUND
  EMAIL_INBOUND
  VOICEMAIL
  NOTE
}

enum ContactOutcome {
  CONNECTED
  NO_ANSWER
  VOICEMAIL
  WRONG_NUMBER
  INTERESTED
  NOT_INTERESTED
  CALLBACK
  DO_NOT_CALL
  SENT
  DELIVERED
  REPLIED
  BOUNCED
}

model ContactLog {
  id          String         @id @default(cuid())
  leadId      String
  lead        Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type        ContactType
  outcome     ContactOutcome?
  duration    Int?
  message     String?
  notes       String?
  scriptUsed  String?
  createdAt   DateTime       @default(now())

  @@index([leadId])
  @@index([createdAt(sort: Desc)])
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  content   String
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
}

// ============================================================
// CALL SCRIPTS
// ============================================================

model CallScript {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  body        String
  description String?
  isDefault   Boolean  @default(false)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// HANDOFFS
// ============================================================

enum HandoffStatus {
  PENDING
  SENT
  ACCEPTED
  UNDER_CONTRACT
  CLOSED
  REJECTED
}

model WholesalePartner {
  id          String    @id @default(cuid())
  name        String
  company     String?
  email       String
  phone       String?
  regions     String[]
  isActive    Boolean   @default(true)
  totalDeals  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  handoffs    Handoff[]
}

model Handoff {
  id          String        @id @default(cuid())
  leadId      String
  lead        Lead          @relation(fields: [leadId], references: [id])
  partnerId   String
  partner     WholesalePartner @relation(fields: [partnerId], references: [id])
  status      HandoffStatus @default(PENDING)
  summary     String?
  whyHot      String?
  notes       String?
  sentAt      DateTime?
  respondedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([leadId])
  @@index([partnerId])
}

// ============================================================
// NOTIFICATIONS
// ============================================================

enum NotificationType {
  NEW_HIGH_SCORE_LEAD
  TIME_SENSITIVE_EVENT
  LEAD_STATUS_CHANGE
  INBOUND_REPLY
  FOLLOW_UP_DUE
  HANDOFF_RESPONSE
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  leadId    String?
  isRead    Boolean          @default(false)
  isDismissed Boolean        @default(false)
  createdAt DateTime         @default(now())

  @@index([isRead, createdAt(sort: Desc)])
}
